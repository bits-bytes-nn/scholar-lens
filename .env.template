GITHUB_TOKEN=
LANGCHAIN_API_KEY=
UPSTAGE_API_KEY=

# Web search for tech-guide deep research (optional). Tavily is preferred (built
# for LLM retrieval — returns cleaned page content); Brave is the fallback. With
# neither set, guides research only the supplied URLs.
TAVILY_API_KEY=
BRAVE_API_KEY=

LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=scholar-lens

# Slack "Paper Bot". Use a DEDICATED Slack app for this bot — do NOT reuse
# another bot's tokens (e.g. OmniSummary).
#
# PRODUCTION path is the Events API behind the receiver Lambda (deployed by CDK):
# it needs SLACK_BOT_TOKEN (xoxb-, chat.postMessage) and SLACK_SIGNING_SECRET.
# Socket Mode (SLACK_APP_TOKEN, xapp-) is now only the LOCAL-DEV fallback
# (`python -m scholar_lens.slack.bot`); two Socket Mode processes sharing one app
# make Slack route each event to only one of them at random.
SLACK_BOT_TOKEN=
# Slack app "Signing Secret" (Basic Information -> App Credentials). The Events
# API receiver verifies each inbound request's HMAC with it. Distinct from the
# xoxb-/xapp- tokens.
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
# Paper Bot's own Slack app id (starts with 'A'). When set, the Socket Mode bot
# refuses to start if SLACK_APP_TOKEN belongs to a different app — a hard guard
# against accidentally binding to another bot's app.
SLACK_EXPECTED_APP_ID=
# Optional comma-separated Slack user ids allowed to trigger jobs (e.g.
# U012ABCDEF,U034GHIJKL). Leave empty to allow any workspace member.
SLACK_ALLOWED_USER_IDS=
